{
    "name": "ragcode/php-bridge",
    "description": "PHP AST bridge for rag-code-mcp using nikic/php-parser",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "nikic/php-parser": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "RagCode\\Bridge\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
